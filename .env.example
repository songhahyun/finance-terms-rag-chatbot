# Local development
GENERATION_PROVIDER=ollama

# Ollama generation
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT=300
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_P=0.8
OLLAMA_REPEAT_PENALTY=1.2
OLLAMA_KEEP_ALIVE=-1

# OpenAI generation, only required when GENERATION_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-4o-mini
GENERATION_TEMPERATURE=0.1
GENERATION_MAX_TOKENS=800

# Backend auth
API_AUTH_REQUIRED=false
API_JWT_SECRET=change-me-in-production
API_JWT_ALGORITHM=HS256
API_JWT_EXP_MINUTES=60
API_ADMIN_USERNAME=admin
API_ADMIN_PASSWORD=admin123
API_ADMIN_ROLE=admin

# Retrieval embeddings
CLOVA_API_KEY=
NCP_APIGW_API_KEY=
CLOVA_EMBEDDING_MODEL=bge-m3

# Chroma vector store
CHROMA_CLIENT_MODE=persistent
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_COLLECTION_NAME=docs_clova

# Data paths
DEFAULT_PDF_FILENAME=2020_경제금융용어 700선.pdf
FINRAG_CHUNK_PATH=data/processed/final_chunk.json

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Monitoring / timeout
MONITOR_STAGE_LOG_PATH=logs/stage_monitor.log
MONITOR_STAGE3_TIMEOUT_SEC=120
